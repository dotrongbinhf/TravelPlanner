# Server Configuration
HOST=0.0.0.0
PORT=8000

# API Keys
# Get your Google API key from: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# Tavily API for web search
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Google Maps Platform API Key (Places, Distance Matrix)
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# .NET API Configuration
# URL of your .NET backend service
DOTNET_API_URL=https://localhost:5001

# Application Settings
APP_NAME=FastAPI Multi-Agent System
DEBUG=True

# LangSmith Tracing (Optional)
# Get your API key from: https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=travel-planner-agents
LANGSMITH_TRACING=False